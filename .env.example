# ============================================================
# AndryBot — configurazione (copia questo file in .env)
# ============================================================

# --- Web / dashboard -----------------------------------------
# Porta interna del server web (Caddy fa da proxy davanti)
PORT=8090
# URL pubblico della dashboard (serve per l'OAuth Twitch)
BASE_URL=https://bot.andryxify.it
# (facoltativo) Segreto dei cookie di sessione: se vuoto viene
# generato automaticamente al primo avvio e salvato in data/.
SESSION_SECRET=

# --- Twitch --------------------------------------------------
# STESSA app Twitch usata da andryxify.it (dev.twitch.tv/console)
# Ricordati di aggiungere fra i "Redirect URI" dell'app:
#   https://bot.andryxify.it/auth/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Login Twitch (minuscolo) degli amministratori, separati da virgola.
# Solo loro vedono il pannello admin e approvano gli streamer.
ADMIN_LOGINS=andryxify

# --- Sito madre ----------------------------------------------
# Il bot si pre-addestra dal profilo dello streamer sul sito,
# controlla periodicamente chi è abilitato e conferma le chiavi
# d'accesso monouso generate dal sito (zero segreti condivisi:
# l'ancora di fiducia è l'HTTPS di andryxify.it).
SITE_URL=https://andryxify.it

# --- Dati ----------------------------------------------------
# Cartella dove vivono database e memoria del bot
DATA_DIR=./data
