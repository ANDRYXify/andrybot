# ============================================================
# AndryBot — configurazione (copia questo file in .env)
# ============================================================

# --- Web / dashboard -----------------------------------------
# Porta interna del server web (Caddy fa da proxy davanti)
PORT=8090
# URL pubblico della dashboard (serve per l'OAuth Twitch)
BASE_URL=https://bot.andryxify.it
# (facoltativo) Segreto dei cookie di sessione: se vuoto viene
# generato automaticamente al primo avvio e salvato in data/.
SESSION_SECRET=

# --- Twitch --------------------------------------------------
# STESSA app Twitch usata da andryxify.it (dev.twitch.tv/console)
# Ricordati di aggiungere fra i "Redirect URI" dell'app:
#   https://bot.andryxify.it/auth/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Login Twitch (minuscolo) degli amministratori, separati da virgola.
# Solo loro vedono il pannello admin e approvano gli streamer.
ADMIN_LOGINS=andryxify

# --- Sito madre ----------------------------------------------
# Il bot si pre-addestra dal profilo dello streamer sul sito,
# controlla periodicamente chi è abilitato e conferma le chiavi
# d'accesso monouso generate dal sito (zero segreti condivisi:
# l'ancora di fiducia è l'HTTPS di andryxify.it).
SITE_URL=https://andryxify.it

# --- Dati ----------------------------------------------------
# Cartella dove vivono database e memoria del bot
DATA_DIR=./data

# --- Cervello / LLM locale (servizio "brain") ----------------
# Il modello si sceglie DA SOLO in base alla RAM (Qwen2.5 Instruct GGUF):
#   8 GB+ (es. Hetzner CX33) → 3B Q5 · 6-7 GB → 3B Q4 · 3 GB → 1.5B · meno → 0.5B
# Di norma NON serve toccare niente. Override solo se vuoi:
# LLM_MODELLO=             # scorciatoia: qwen | gemma | gemma-uncensored
#   gemma-uncensored = Gemma 2 2B "abliterated" (senza rifiuti/tono da manuale),
#   più libero per una chat Twitch. NB: restano la moderazione del bot + le
#   "parole vietate" a filtrare l'uscita, e le regole di Twitch valgono sempre.
# LLM_MODEL_URL=           # in alternativa, l'URL GGUF completo (ignora LLM_MODELLO e la scaletta)
#   (il codice gestisce da sé le differenze di Gemma, es. l'assenza del ruolo "system")
# LLM_MODEL_PATH=          # usa un file GGUF locale (es. un tuo fine-tune) in data/models
# HF_TOKEN=                # token HuggingFace: serve SOLO per modelli "gated" (alcune varianti Gemma)
# LLM_CONTEXT=1024         # memoria di conversazione (2048 = più contesto, un filo più lento)
# LLM_MAX_TOKEN=80         # lunghezza massima della risposta
#
# --- Maestro esterno (LM Studio / Ollama / OpenAI-compatibile) — FACOLTATIVO ---
# Collega un modello che gira sul TUO PC (più potente del server): il bot lo usa
# come "maestro" e la piccola rete impara da ogni sua risposta. Si configura anche
# dalla dashboard (Admin → Cervello). Dev'essere raggiungibile DAL SERVER (LAN,
# IP pubblico o tunnel tipo cloudflared/ngrok).
# LLM_ENDPOINT_URL=        # es. http://IP:1234/v1  (LM Studio)  ·  http://IP:11434/v1 (Ollama)
# LLM_ENDPOINT_MODELLO=    # nome del modello caricato (facoltativo; LM Studio usa quello attivo)
# LLM_ENDPOINT_CHIAVE=     # chiave API se l'endpoint la richiede (di solito vuota in locale)
# LLM_ENDPOINT_SOLO=       # 1 = non caricare il modello locale (usa solo l'endpoint: libera la RAM)

# --- Abbonamenti Stripe (self-service) — FACOLTATIVO ---------
# Lascia vuoto per tenere Stripe SPENTO (il bot resta gratis per la community).
# Si accende da solo appena SECRET_KEY + WEBHOOK_SECRET sono presenti.
# Webhook da creare su Stripe → endpoint: https://bot.andryxify.it/stripe/webhook
STRIPE_SECRET_KEY=          # sk_live_... (o sk_test_... per provare)
STRIPE_WEBHOOK_SECRET=      # whsec_... (il "signing secret" del webhook)
STRIPE_PRICE_BASE=          # price_... del piano Base
STRIPE_PRICE_PRO=           # price_... del piano Pro
